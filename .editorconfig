root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{toml,md}]
trim_trailing_whitespace = false

[*.lua]
indent_size = 2

# git config uses tabs by convention
[gitconfig]
indent_style = tab
